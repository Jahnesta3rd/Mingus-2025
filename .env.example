# Mingus Application - Environment Template
# Copy this file to .env and update the values for your environment

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/mingus

# API Keys
FRED_API_KEY=

# SEC EDGAR (required for CR9 employer health)
# Format: 'AppName ContactEmail' — SEC blocks requests without this
SEC_USER_AGENT="Mingus Application your-email@example.com"
