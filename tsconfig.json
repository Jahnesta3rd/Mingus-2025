{
  "compilerOptions": {
    "target": "es2015",
    "lib": ["es2015", "dom"],
    "types": ["cypress", "node"],
    "strict": true,
    "isolatedModules": false,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "module": "commonjs",
    "noEmit": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["cypress/**/*.ts", "cypress.config.ts"]
}
